# Parley — environment variables
# Copy to .env and fill in. Never commit .env.

# ---------------------------------------------------------------------------
# Execution mode
# ---------------------------------------------------------------------------
# "paper" (Binance testnet) or "live" (Binance mainnet).
# The supervisor also reads .claude/settings.json `mode` — both must agree.
PARLEY_MODE=paper

# ---------------------------------------------------------------------------
# Database — Neon Postgres
# ---------------------------------------------------------------------------
# Full connection string, e.g.
#   postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/parley?sslmode=require
DATABASE_URL=

# ---------------------------------------------------------------------------
# Binance — testnet (paper)
# ---------------------------------------------------------------------------
# Create at https://testnet.binance.vision/
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_REST_URL=https://testnet.binance.vision
BINANCE_TESTNET_WS_URL=wss://stream.testnet.binance.vision

# ---------------------------------------------------------------------------
# Binance — live (future phase; leave blank in paper mode)
# ---------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443

# ---------------------------------------------------------------------------
# Market data / research inputs (optional)
# ---------------------------------------------------------------------------
# Used by desk/cycle.py gather-research. Leave blank to skip a source.
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=
MESSARI_API_KEY=

# ---------------------------------------------------------------------------
# Dashboard (Next.js in dashboard/)
# ---------------------------------------------------------------------------
# Read-only DSN preferred. Falls back to DATABASE_URL if unset.
DASHBOARD_DATABASE_URL=
DASHBOARD_PORT=3000

# ---------------------------------------------------------------------------
# Operator / ops
# ---------------------------------------------------------------------------
# Timezone for operator-facing logs. Database timestamps are always UTC.
OPERATOR_TZ=America/Mexico_City
# Optional: webhook for incident alerts (Slack, Discord, etc.)
INCIDENT_WEBHOOK_URL=
